rules_version = '2';
// Firestore セキュリティルール — 承認された職員のみ読み書き可。
// Firebase の apiKey は公開情報のため「ログインしていれば読める」では不十分
// （誰でも self-signup できてしまう）。管理者が staff/{uid} を作成した職員だけに限定する。
service cloud.firestore {
  match /databases/{database}/documents {

    // 承認済み職員か（管理者が staff/{uid} を作成。self-signup では staff 文書が無く読めない）
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // 職員許可リスト。承認済み職員はアプリの「職員管理」で一覧・追加・解除できる（全員同権限）。
    // 最初の 1 人だけは CLI(grant-staff.mjs / Admin SDK)で承認する（ルールをすり抜ける）。
    match /staff/{uid} {
      allow read: if isStaff() || (request.auth != null && request.auth.uid == uid);
      allow create, update, delete: if isStaff();
    }

    // 読み取りキュー(OCR 結果)。作成はバックエンド(Admin SDK)が行うためルールをすり抜ける。
    // クライアントは閲覧と、確認・本登録に伴うステータス更新のみ許可する。
    match /batches/{batchId} {
      allow read: if isStaff();
      allow write: if false; // メタ更新はバックエンドのみ

      match /recognitions/{recognitionId} {
        allow read: if isStaff();
        // 職員による確認・本登録の反映のみ許可(status / 解決値 / 照合ユーザ)。新規作成・削除は不可。
        allow update: if isStaff()
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'resolvedValues', 'matchedUserId', 'reviewedBy', 'reviewedAt']);
        allow create, delete: if false;
      }
    }

    // 利用者台帳。承認職員が閲覧・編集可（氏名・市町村/行政区・介護度・電話 等）。削除は不可。
    match /users/{userId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if false;
    }

    // 測定データ。承認職員が閲覧・作成・編集可（実データ取り込み後の修正を含む）。削除は不可(監査性)。
    match /measurements/{measurementId} {
      allow read: if isStaff();
      allow create, update: if isStaff()
        && request.resource.data.keys().hasAll(['userId', 'year']);
      allow delete: if false;
    }
  }
}
