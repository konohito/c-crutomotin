# functions/.env — ローカルエミュレータ用の設定例。実際の値を入れて functions/.env として保存する。
# 本番(デプロイ)では `firebase functions:secrets` か環境変数で設定する。

# --- Document AI ---
# GCP プロジェクト ID(Cloud Functions 上では自動設定されるためローカルのみ必要)
DOCAI_PROJECT_ID=your-gcp-project-id
# Document AI プロセッサのロケーション: us / eu など
DOCAI_LOCATION=us
# 作成した Form Parser もしくはカスタム抽出プロセッサの ID
DOCAI_PROCESSOR_ID=xxxxxxxxxxxxxxxx

# --- 任意 ---
# 簡易 API キー(設定するとフロントの VITE_OCR_API_KEY と一致必須になる)
OCR_API_KEY=
# CORS 許可オリジン(本番は SPA の URL を指定。例: https://konohito.github.io)
OCR_ALLOW_ORIGIN=*
# 画像サイズ上限(バイト)
OCR_MAX_BYTES=10485760
# 要確認しきい値(%)。フロントの CONF_THRESHOLD と揃える
OCR_REVIEW_THRESHOLD=80
