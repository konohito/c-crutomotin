{
  "name": "cruto-motion-ocr-functions",
  "description": "Cruto motion — 記録用紙 OCR バックエンド (Firebase Functions + Google Document AI)",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "scripts": {
    "test": "node test/mapping.test.cjs && node test/recognition.test.cjs && node test/mockdoc.test.cjs",
    "test:e2e": "firebase emulators:exec --project demo-cruto --only functions,firestore,storage \"node test/e2e-pipeline.cjs\"",
    "serve": "firebase emulators:start --only functions,firestore,storage",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log --only recognizeSheet"
  },
  "dependencies": {
    "@google-cloud/documentai": "^8.11.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^6.6.0"
  },
  "devDependencies": {
    "firebase-tools": "^13.23.0"
  }
}
